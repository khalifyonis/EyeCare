{
    "name": "eye-care-root",
    "version": "1.0.0",
    "description": "Root package for Eye Care System",
    "scripts": {
        "start:backend": "cd backend && npm start",
        "start:frontend": "cd frontend && npm run dev",
        "dev": "concurrently --names \"api,web\" \"npm run start:backend\" \"npm run start:frontend\"",
        "restart": "node scripts/kill-ports.js && npm run dev",
        "install-all": "npm install --prefix backend && npm install --prefix frontend"
    },
    "devDependencies": {
        "concurrently": "^9.2.1"
    }
}