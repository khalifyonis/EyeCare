// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Roles & Security ──

model Role {
  id          String  @id @default(uuid())
  name        String  @unique // SUPERADMIN, ADMIN, DOCTOR, RECEPTIONIST, OPTICIAN, PHARMACIST
  description String?
  users       User[]

  @@map("roles")
}

// ── Core Tables ──

model Branch {
  id         String   @id @default(uuid())
  branchName String   @map("branch_name")
  address    String
  phone      String
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relationships
  users                User[]
  staffAssignments     StaffAssignment[]
  doctors              Doctor[]
  patients             Patient[]
  appointments         Appointment[]
  surgeries            Surgery[]
  prescriptions        Prescription[]
  pharmacyItems        PharmacyItem[]
  pharmacyTransactions PharmacyStockTransaction[]
  opticalItems         OpticalItem[]
  opticalTransactions  OpticalStockTransaction[]
  billings             Billing[]

  @@map("clinic_branch")
}

model User {
  id               String    @id @default(uuid())
  fullName         String    @map("full_name")
  username         String    @unique
  email            String    @unique
  password         String
  phone            String?
  resetToken       String?   @unique @map("reset_token")
  resetTokenExpiry DateTime? @map("reset_token_expiry")
  profileImage     String?   @map("profile_image")
  isActive         Boolean   @default(true) @map("is_active")

  // Multi-tenancy & Governance
  roleId   String @map("role_id")
  role     Role   @relation(fields: [roleId], references: [id])
  branchId String @map("branch_id")
  branch   Branch @relation(fields: [branchId], references: [id])

  // Many-to-Many Staff Assignments
  staffAssignments StaffAssignment[]

  // Audit Fields
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relationships
  doctor               Doctor?
  createdAppointments  Appointment[]              @relation("CreatedBy")
  recordedERExams      ERExamination[]            @relation("RecordedBy")
  pharmacyTransactions PharmacyStockTransaction[] @relation("PerformedBy")
  opticalTransactions  OpticalStockTransaction[]  @relation("PerformedBy")
  createdBillings      Billing[]                  @relation("CreatedBy")

  @@map("users")
}

model StaffAssignment {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  branchId   String   @map("branch_id")
  branch     Branch   @relation(fields: [branchId], references: [id])
  isPrimary  Boolean  @default(false) @map("is_primary")
  assignedAt DateTime @default(now()) @map("assigned_at")

  @@unique([userId, branchId])
  @@map("staff_assignments")
}

model Doctor {
  id             String  @id @default(uuid())
  userId         String  @unique @map("user_id")
  user           User    @relation(fields: [userId], references: [id])
  licenseNumber  String  @unique @map("license_number")
  specialization String
  phone          String?

  branchId String @map("branch_id")
  branch   Branch @relation(fields: [branchId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relationships
  appointments          Appointment[]
  examinedClinicalExams ClinicalExamination[] @relation("ExaminedBy")
  surgeries             Surgery[]             @relation("Surgeon")

  @@map("doctors")
}

// ── Patient CRM ──

model Patient {
  id          String   @id @default(uuid())
  patientId   String   @unique @map("patient_id")
  firstName   String   @map("first_name")
  lastName    String   @map("last_name")
  gender      String?
  dateOfBirth DateTime @map("date_of_birth")
  phone       String   @unique
  email       String?
  address     String?

  branchId String @map("branch_id")
  branch   Branch @relation(fields: [branchId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relationships
  appointments Appointment[]
  billings     Billing[]

  @@map("patients")
}

// ── Clinical Tables ──

enum AppointmentStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model Appointment {
  id              String            @id @default(uuid())
  bookingNumber   String            @unique @map("booking_number")
  appointmentDate DateTime          @map("appointment_date")
  status          AppointmentStatus @default(PENDING)
  amount          Decimal           @default(0) @db.Decimal(10, 2)

  branchId  String  @map("branch_id")
  branch    Branch  @relation(fields: [branchId], references: [id])
  patientId String  @map("patient_id")
  patient   Patient @relation(fields: [patientId], references: [id])
  doctorId  String  @map("doctor_id")
  doctor    Doctor  @relation(fields: [doctorId], references: [id])

  createdById String @map("created_by")
  createdBy   User   @relation("CreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relationships
  erExamination       ERExamination?
  clinicalExamination ClinicalExamination?
  prescriptions       Prescription[]
  billings            Billing[]

  @@map("appointments")
}

model ERExamination {
  id            String      @id @default(uuid())
  appointmentId String      @unique @map("appointment_id")
  appointment   Appointment @relation(fields: [appointmentId], references: [id])

  vaRight  String?  @map("va_right")
  vaLeft   String?  @map("va_left")
  phRight  String?  @map("ph_right")
  phLeft   String?  @map("ph_left")
  iopRight Decimal? @map("iop_right") @db.Decimal(10, 2)
  iopLeft  Decimal? @map("iop_left") @db.Decimal(10, 2)
  notes    String?

  recordedById String @map("recorded_by")
  recordedBy   User   @relation("RecordedBy", fields: [recordedById], references: [id])

  createdAt DateTime @default(now()) @map("recorded_at")

  @@map("er_examinations")
}

model ClinicalExamination {
  id            String      @id @default(uuid())
  appointmentId String      @unique @map("appointment_id")
  appointment   Appointment @relation(fields: [appointmentId], references: [id])

  sphRight  Decimal? @map("sph_right") @db.Decimal(10, 2)
  cylRight  Decimal? @map("cyl_right") @db.Decimal(10, 2)
  axisRight Int?     @map("axis_right")
  sphLeft   Decimal? @map("sph_left") @db.Decimal(10, 2)
  cylLeft   Decimal? @map("cyl_left") @db.Decimal(10, 2)
  axisLeft  Int?     @map("axis_left")

  diagnosis      String?
  managementPlan String? @map("management_plan")

  examinedById String @map("examined_by")
  examinedBy   Doctor @relation("ExaminedBy", fields: [examinedById], references: [id])

  examinedAt DateTime @default(now()) @map("examined_at")

  // Relationships
  surgery       Surgery?
  prescriptions Prescription[]

  @@map("clinical_examinations")
}

model Surgery {
  id           String              @id @default(uuid())
  examId       String              @unique @map("exam_id")
  clinicalExam ClinicalExamination @relation(fields: [examId], references: [id])

  branchId String @map("branch_id")
  branch   Branch @relation(fields: [branchId], references: [id])

  eyeSide     String   @map("eye_side") // RIGHT, LEFT, BOTH
  surgeryType String   @map("surgery_type")
  surgeryDate DateTime @map("surgery_date")
  cost        Decimal  @db.Decimal(10, 2)
  status      String   @default("PENDING")
  notes       String?

  surgeonId String @map("surgeon_id")
  surgeon   Doctor @relation("Surgeon", fields: [surgeonId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  // Relationships
  billings Billing[]

  @@map("surgeries")
}

model Prescription {
  id            String              @id @default(uuid())
  appointmentId String              @map("appointment_id")
  appointment   Appointment         @relation(fields: [appointmentId], references: [id])
  examId        String              @map("exam_id")
  clinicalExam  ClinicalExamination @relation(fields: [examId], references: [id])

  branchId String @map("branch_id")
  branch   Branch @relation(fields: [branchId], references: [id])

  itemType     String  @map("item_type") // PHARMACY, OPTICAL
  itemId       String? @map("item_id")
  quantity     Int
  instructions String?

  createdAt DateTime @default(now()) @map("created_at")

  // Relationships
  billings Billing[]

  @@map("prescriptions")
}

// ── Inventory Tables ──

model PharmacyItem {
  id       String @id @default(uuid())
  branchId String @map("branch_id")
  branch   Branch @relation(fields: [branchId], references: [id])

  itemName      String    @map("item_name")
  itemType      String?   @map("item_type") // Tablet, Syrup, etc.
  category      String? // Antibiotic, Painkiller, etc.
  manufacturer  String? // Cidda samaysay
  supplierName  String?   @map("supplier_name") // Cidda laga soo iibiyey
  batchNumber   String?   @map("batch_number")
  stockQuantity Int       @default(0) @map("stock_quantity")
  reorderLevel  Int       @default(10) @map("reorder_level")
  purchasePrice Decimal   @map("purchase_price") @db.Decimal(10, 2)
  sellingPrice  Decimal   @map("selling_price") @db.Decimal(10, 2)
  expiryDate    DateTime? @map("expiry_date")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relationships
  transactions PharmacyStockTransaction[]

  @@map("pharmacy_items")
}

model PharmacyStockTransaction {
  id             String       @id @default(uuid())
  pharmacyItemId String       @map("pharmacy_item_id")
  pharmacyItem   PharmacyItem @relation(fields: [pharmacyItemId], references: [id])
  branchId       String       @map("branch_id")
  branch         Branch       @relation(fields: [branchId], references: [id])

  transactionType String  @map("transaction_type") // IN, OUT, ADJUST
  quantity        Int
  unitPrice       Decimal @map("unit_price") @db.Decimal(10, 2)

  billingId String?  @map("billing_id")
  billing   Billing? @relation(fields: [billingId], references: [id])

  performedById String @map("performed_by")
  performedBy   User   @relation("PerformedBy", fields: [performedById], references: [id])

  transactionDate DateTime @default(now()) @map("transaction_date")

  @@map("pharmacy_stock_transactions")
}

model OpticalItem {
  id       String @id @default(uuid())
  branchId String @map("branch_id")
  branch   Branch @relation(fields: [branchId], references: [id])

  itemName      String  @map("item_name")
  itemType      String? @map("item_type") // Frame, Lens, Solution
  brand         String?
  manufacturer  String? // Cidda samaysay
  supplierName  String? @map("supplier_name") // Cidda laga soo iibiyey
  stockQuantity Int     @default(0) @map("stock_quantity")
  reorderLevel  Int     @default(5) @map("reorder_level")
  purchasePrice Decimal @map("purchase_price") @db.Decimal(10, 2)
  sellingPrice  Decimal @map("selling_price") @db.Decimal(10, 2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relationships
  transactions OpticalStockTransaction[]

  @@map("optical_items")
}

model OpticalStockTransaction {
  id            String      @id @default(uuid())
  opticalItemId String      @map("optical_item_id")
  opticalItem   OpticalItem @relation(fields: [opticalItemId], references: [id])
  branchId      String      @map("branch_id")
  branch        Branch      @relation(fields: [branchId], references: [id])

  transactionType String  @map("transaction_type")
  quantity        Int
  unitPrice       Decimal @map("unit_price") @db.Decimal(10, 2)

  billingId String?  @map("billing_id")
  billing   Billing? @relation(fields: [billingId], references: [id])

  performedById String @map("performed_by")
  performedBy   User   @relation("PerformedBy", fields: [performedById], references: [id])

  transactionDate DateTime @default(now()) @map("transaction_date")

  @@map("optical_stock_transactions")
}

// ── Billing Module ──

enum ServiceType {
  APPOINTMENT
  PHARMACY
  OPTICAL
  SURGERY
}

enum BillingStatus {
  PAID
  UNPAID
  PARTIAL
}

model Billing {
  id        String  @id @default(uuid())
  patientId String  @map("patient_id")
  patient   Patient @relation(fields: [patientId], references: [id])
  branchId  String  @map("branch_id")
  branch    Branch  @relation(fields: [branchId], references: [id])

  appointmentId  String?       @map("appointment_id")
  appointment    Appointment?  @relation(fields: [appointmentId], references: [id])
  surgeryId      String?       @map("surgery_id")
  surgery        Surgery?      @relation(fields: [surgeryId], references: [id])
  prescriptionId String?       @map("prescription_id")
  prescription   Prescription? @relation(fields: [prescriptionId], references: [id])

  serviceType ServiceType @map("service_type")
  totalAmount Decimal     @map("total_amount") @db.Decimal(10, 2)
  discount    Decimal     @default(0) @db.Decimal(10, 2)
  finalAmount Decimal     @map("final_amount") @db.Decimal(10, 2)

  paymentMethod   String?       @map("payment_method")
  referenceNumber String?       @map("reference_number")
  status          BillingStatus @default(UNPAID)

  createdById String @map("created_by")
  createdBy   User   @relation("CreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Reverse relationships for inventory tracking
  pharmacyTransactions PharmacyStockTransaction[]
  opticalTransactions  OpticalStockTransaction[]

  @@map("billing")
}
